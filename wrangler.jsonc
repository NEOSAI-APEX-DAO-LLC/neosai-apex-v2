{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neosai-apex-dao",
  "compatibility_date": "2026-04-26",
  "main": "src/index.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "neosai_apex",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "VAULT",
      "bucket_name": "neosai-vault"
    },
    {
      "binding": "MATRIX_DATA",
      "bucket_name": "neosai-matrix-data"
    }
  ]
}
